# --- Бренд / инстанс (CLAUDE.md: бренд не зашивается в код) -------------------
BRAND_NAME=Maison

# --- Django ------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://localhost

# Суперпользователь-админ создаётся сидами при первом запуске (смените пароль!)
DJANGO_ADMIN_USERNAME=admin
DJANGO_ADMIN_PASSWORD=admin
DJANGO_ADMIN_EMAIL=admin@example.com

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_DB=orderledger
POSTGRES_USER=orderledger
POSTGRES_PASSWORD=orderledger

# --- nginx -------------------------------------------------------------------
# Внешний порт сайта (http://localhost:8080 по умолчанию)
HTTP_PORT=8080
